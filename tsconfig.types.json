{
  "compilerOptions": {
    "declaration": true,
    "isolatedModules": false,
    "noEmit": false,
    "allowJs": false,
    "emitDeclarationOnly": true,
    "baseUrl": ".",
    "outFile": "./build/dist/prozorro-eds.d.ts",
    "declarationMap": true,
    "skipLibCheck": true,
    "target": "ESNext",
    "module": "esnext",
    "moduleResolution": "Node",
    "types": ["vite/client", "node"],
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "lib": ["ESNext", "DOM"],
    "paths": {
      "@/*": ["./src/*"],
      "@@/*": ["./*"]
    }
  },
  "files": ["./src/services/Eds.ts"],
  "type": "module"
}
